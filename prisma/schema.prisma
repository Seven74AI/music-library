generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  username         String            @unique
  name             String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  connections      Connection[]
  passkey          Passkey[]
  password         Password?
  servicePlaylists ServicePlaylist[]
  sessions         Session[]
  image            UserImage?
  playlists        UserPlaylist[]
  userTracks       UserTrack[]
  roles            Role[]            @relation("RoleToUser")
}

model UserImage {
  id        String   @id @default(cuid())
  altText   String?
  objectKey String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Password {
  hash   String
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id             String   @id @default(cuid())
  expirationDate DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Permission {
  id          String   @id @default(cuid())
  action      String
  entity      String
  access      String
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]   @relation("PermissionToRole")

  @@unique([action, entity, access])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String       @default("")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  permissions Permission[] @relation("PermissionToRole")
  users       User[]       @relation("RoleToUser")
}

model Verification {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  /// The type of verification, e.g. "email" or "phone"
  type      String
  /// The thing we're trying to verify, e.g. a user's email or phone number
  target    String
  /// The secret key used to generate the otp
  secret    String
  /// The algorithm used to generate the otp
  algorithm String
  /// The number of digits in the otp
  digits    Int
  /// The number of seconds the otp is valid for
  period    Int
  /// The valid characters for the otp
  charSet   String
  /// When it's safe to delete this verification
  expiresAt DateTime?

  @@unique([target, type])
}

model Connection {
  id           String   @id @default(cuid())
  providerName String
  providerId   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  tokens       String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerName, providerId])
}

model Passkey {
  id             String   @id
  aaguid         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  publicKey      Bytes
  userId         String
  webauthnUserId String
  counter        BigInt
  deviceType     String
  backedUp       Boolean
  transports     String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Track {
  id                    String                 @id @default(cuid())
  title                 String
  artist                String
  serviceId             String?
  externalId            String?
  serviceUrl            String?
  duration              Int?
  thumbnailUrl          String?
  album                 String?
  releaseDate           DateTime?
  // Basic metadata
  genre                 String?
  year                  Int?
  trackNumber           Int?
  albumArtist           String?
  // Additional metadata
  bpm                   Int?
  label                 String?
  isrc                  String?
  originalDate          DateTime?
  originalYear          Int?
  totalTracks           Int?
  totalDiscs            Int?
  lyrics                String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  servicePlaylistTracks ServicePlaylistTrack[]
  service               Service?               @relation(fields: [serviceId], references: [id])
  playlists             UserPlaylistTrack[]
  userTracks            UserTrack[]
  audioFiles            TrackAudioFile[]

  @@unique([serviceId, externalId])
  @@index([serviceId, externalId])
  @@index([updatedAt])
  @@index([createdAt])
}

model UserPlaylist {
  id          String              @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  ownerId     String
  owner       User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tracks      UserPlaylistTrack[]

  @@index([ownerId])
  @@index([ownerId, updatedAt])
}

model UserPlaylistTrack {
  id         String       @id @default(cuid())
  position   Int
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  playlistId String
  trackId    String
  track      Track        @relation(fields: [trackId], references: [id], onDelete: Cascade)
  playlist   UserPlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId, position])
}

model Service {
  id          String            @id @default(cuid())
  name        String            @unique
  displayName String
  baseUrl     String
  logoUrl     String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  playlists   ServicePlaylist[]
  tracks      Track[]
  audioFiles  TrackAudioFile[]

  @@index([name])
}

model UserTrack {
  id        String    @id @default(cuid())
  userId    String
  trackId   String
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  track     Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([userId])
  @@index([trackId])
  @@index([userId, isActive])
  @@index([userId, createdAt])
}

model ServicePlaylist {
  id           String                 @id @default(cuid())
  serviceId    String
  externalId   String
  title        String
  description  String?
  thumbnailUrl String?
  channelId    String?
  channelTitle String?
  publishedAt  DateTime?
  itemCount    Int
  lastSyncedAt DateTime?
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  ownerId      String
  owner        User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  service      Service                @relation(fields: [serviceId], references: [id])
  tracks       ServicePlaylistTrack[]

  @@unique([serviceId, externalId])
  @@index([ownerId])
  @@index([ownerId, updatedAt])
  @@index([serviceId, externalId])
}

model ServicePlaylistTrack {
  id         String          @id @default(cuid())
  playlistId String
  trackId    String
  position   Int
  isDeleted  Boolean         @default(false)
  deletedAt  DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  track      Track           @relation(fields: [trackId], references: [id])
  playlist   ServicePlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
  @@index([playlistId])
  @@index([trackId])
  @@index([playlistId, isDeleted])
}

model TrackAudioFile {
  id      String @id @default(cuid())
  trackId String
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  // Service attribution
  serviceId String? // null = local upload, otherwise references Service
  service   Service? @relation(fields: [serviceId], references: [id])

  // File storage
  objectKey String // S3 storage key
  fileName  String?
  fileSize  Int?
  mimeType  String? // audio/mpeg, audio/flac, etc.
  format    String? // "mp3", "flac", "wav", etc.

  // Audio metadata
  bitrate    Int? // kbps
  sampleRate Int? // Hz

  // Upload info
  uploadedAt DateTime @default(now())
  uploadedBy String? // userId who uploaded (for local uploads)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([trackId, serviceId, format]) // One file per track/service/format combination
  @@index([trackId])
  @@index([serviceId])
  @@index([format])
  @@index([trackId, format]) // Quick lookup: "get MP3 for this track"
}
